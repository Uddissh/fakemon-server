# ============================================================
# Fakemon Chaos — Environment Variables
# File:  .env.example
# Repo:  fakemon-server (Uddissh)
#
# INSTRUCTIONS:
#   1. Copy this file to .env
#   2. Fill in ALL values before running the server
#   3. NEVER commit .env to git — it is in .gitignore
#   4. Share actual secret values with your teammate via
#      Bitwarden (or equivalent) — NOT Discord DMs
#
# .env.example IS committed to git as a reference.
# It contains only placeholder values, never real secrets.
# ============================================================

# ──────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# Publicly accessible base URL of this auth server.
# Used for Discord OAuth callback URL construction.
# Development: http://localhost:3001
# Production:  https://api.fakemonchaos.com
API_BASE_URL=http://localhost:3001

# ──────────────────────────────────────────────────────────
# JWT
# Shared between fakemon-server AND fakemon-showdown.
# BOTH repos must have the SAME value for this variable.
# Generate with: openssl rand -base64 64
# ──────────────────────────────────────────────────────────

JWT_SHARED_SECRET=replace_with_a_long_random_string_minimum_64_chars
JWT_EXPIRY_SECONDS=3600

# ──────────────────────────────────────────────────────────
# DISCORD OAUTH2
# Create an application at: https://discord.com/developers/applications
# Add redirect URI: API_BASE_URL/auth/discord/callback
# ──────────────────────────────────────────────────────────

DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# ──────────────────────────────────────────────────────────
# PATREON
# Create a client at: https://www.patreon.com/portal/registration/register-clients
# Webhook secret is set when creating the webhook in the Patreon dashboard.
# Campaign ID is the numeric ID of your Patreon campaign page.
# ──────────────────────────────────────────────────────────

PATREON_CLIENT_ID=your_patreon_client_id
PATREON_CLIENT_SECRET=your_patreon_client_secret
PATREON_WEBHOOK_SECRET=your_patreon_webhook_signing_secret
PATREON_CAMPAIGN_ID=your_patreon_campaign_id

# Patreon tier ID → platform tier mapping.
# Find tier IDs in the Patreon API response for your campaign.
# Format: PATREON_TIER_ID_<PLATFORM_TIER_NUMBER>=<patreon_tier_id>
PATREON_TIER_ID_1=patreon_tier_id_for_member_1_dollar
PATREON_TIER_ID_2=patreon_tier_id_for_chaos_casual_5_dollar
PATREON_TIER_ID_3=patreon_tier_id_for_supreme_chaos_10_dollar
PATREON_TIER_ID_4=patreon_tier_id_for_server_legend_25_dollar

# ──────────────────────────────────────────────────────────
# DATABASE
# Supabase PostgreSQL connection string.
# Find in: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format (not pooler for migrations).
# ──────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# For connection pooling in production (use with Supabase Pooler):
DATABASE_POOL_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# ──────────────────────────────────────────────────────────
# CLOUDINARY
# Create a free account at: https://cloudinary.com
# Find credentials in: Dashboard → API Keys
# All sprite uploads go through this account.
# ──────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cloudinary upload preset for sprites (create in Cloudinary dashboard).
# Set it to "unsigned" for client-side uploads or "signed" for server-side.
# Recommendation: signed (server-side) for security.
CLOUDINARY_UPLOAD_PRESET=fakemon_sprites

# ──────────────────────────────────────────────────────────
# CORS
# Comma-separated list of allowed origins.
# Development: http://localhost:5173 (Vite default)
# Production:  https://play.fakemonchaos.com
# ──────────────────────────────────────────────────────────

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────
# SESSION
# Used for OAuth2 state parameter storage (short-lived).
# Generate with: openssl rand -base64 32
# ──────────────────────────────────────────────────────────

SESSION_SECRET=replace_with_random_32_char_string

# ──────────────────────────────────────────────────────────
# SHOWDOWN INTERNAL API
# The auth server may need to communicate with the Showdown
# server for matchmaking queue management.
# Development: http://localhost:8000
# Production:  internal Docker network URL or teammate's host
# ──────────────────────────────────────────────────────────

SHOWDOWN_INTERNAL_URL=http://localhost:8000
SHOWDOWN_INTERNAL_SECRET=replace_with_shared_internal_api_secret

# ──────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────

# Max requests per IP per 15-minute window on general API routes.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stricter limit on auth routes (OAuth callback, token refresh).
RATE_LIMIT_AUTH_MAX_REQUESTS=20

# ──────────────────────────────────────────────────────────
# MODERATION
# ──────────────────────────────────────────────────────────

# Number of unique flags within the window before a sprite is auto-rejected.
SPRITE_FLAG_THRESHOLD=3
# Time window in hours for the flag threshold check.
SPRITE_FLAG_WINDOW_HOURS=72
# Hours before a pending sprite is auto-approved if zero flags received.
SPRITE_AUTO_APPROVE_HOURS=24
# Minimum account age in days before sprite upload is unlocked.
SPRITE_UPLOAD_MIN_ACCOUNT_AGE_DAYS=7

# ──────────────────────────────────────────────────────────
# LOGGING
# Levels: error | warn | info | debug
# Use "debug" locally, "info" or "warn" in production.
# ──────────────────────────────────────────────────────────

LOG_LEVEL=debug
